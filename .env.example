# crates.io API token (create at https://crates.io/settings/tokens).
# Copy to `.env` and paste your token. Never commit `.env`.
#
# Local publish (recommended for one-off):
#   cargo login
#   # paste token when prompted — stored in ~/.cargo/credentials.toml
#
# Or non-interactive / CI:
#   export CARGO_REGISTRY_TOKEN="your-token"
#   cargo publish --dry-run
#   cargo publish
#
# This file is optional; some teams load `.env` into the shell for scripts only.
